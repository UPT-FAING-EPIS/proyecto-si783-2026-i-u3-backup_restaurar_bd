{
  "name": "safebridge-vscode",
  "displayName": "SafeBridge Verifier",
  "description": "Verificación de integridad de archivos de copias de seguridad locales",
  "version": "1.0.0",
  "publisher": "safebridge",
  "repository": { "type": "git", "url": "https://github.com/safebridge" },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "safebridge.verificarBackup",
        "title": "SafeBridge: Verificar integridad de Backup"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3",
    "esbuild": "^0.18.11"
  }
}
